# =========================================================
#  VARIABLES DE ENTORNO DEL BACKEND
#  Copia este archivo como ".env" y completa los valores.
#  (El archivo .env NUNCA debe subirse a GitHub)
# =========================================================

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- Base de datos MySQL ----
# En Railway estos valores te los da el panel de la base de datos.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventario_talleres
DB_USER=root
DB_PASS=tu_password_mysql

# ---- Seguridad / JWT ----
# Genera una cadena larga y aleatoria. Ej: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_una_clave_larga_y_secreta
JWT_EXPIRES_IN=8h

# ---- Cloudinary (imágenes gratuitas) ----
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ---- URLs ----
# URL pública del frontend (GitHub Pages). Se usa para CORS y para los QR.
FRONTEND_URL=http://localhost:5500

# Usuario administrador inicial (lo crea el script "npm run seed")
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@taller.local
ADMIN_PASSWORD=Admin1234
